# Copiá este archivo a ".env" en la MISMA carpeta (apps/api/.env) y completá los valores.
# Guía: docs/SUPABASE_ENV.md

PORT=3001
NODE_ENV=development

# ─── Postgres (Prisma) ───────────────────────────────────────────────────────
# Supabase Dashboard → Connect (arriba) o Database → Connection string.
#
# Si Prisma dice "Can't reach" con host db.PROJECT.supabase.co: la URI DIRECT suele ser IPv6-only.
# Solución en Windows / redes IPv4: elegí "Session pooler" en Connect y pegá esa URI en DATABASE_URL.
# Doc: https://supabase.com/docs/guides/database/connecting-to-postgres
#
# Shared pooler / Session (IPv4): host sale del botón Connect → Session pooler (ej. aws-1-<región>).
# Ejemplo PreciosYa sa-east-1 (reemplazá [YOUR-PASSWORD]; agregá ?sslmode=require si el panel no lo trae):
# DATABASE_URL=postgresql://postgres.ubyegvbrvyknitjkzrsh:[YOUR-PASSWORD]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
#
# Transaction pooler (6543) + Prisma: suele requerir ?pgbouncer=true y otras notas; para esta API preferí Session.
# DIRECT_URL: opcional; URI "directa" para prisma migrate si más adelante usás pooler transaccional (IPv6 o CI).
DATABASE_URL=
DIRECT_URL=

# ─── Supabase API (backend) ─────────────────────────────────────────────────
# Dashboard: Project Settings → API  (Project URL SIN /rest/v1)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

JWT_SECRET=change_me_min_32_characters_long_string
RESEND_API_KEY=
# Mismo origen que la URL del navegador (ej. http://localhost:5173 o :5174 si Vite cambió puerto)
FRONTEND_URL=http://localhost:5173
INDEC_API_BASE_URL=https://apis.datos.gob.ar/series/api
BCRA_API_BASE_URL=https://api.bcra.gob.ar
