# Copiar a apps/api/.env — ver docs/SUPABASE_ENV.md

PORT=3001
NODE_ENV=development

# Postgres: Connect → Session pooler si "Can't reach" con db.*.supabase.co (IPv4).
DATABASE_URL=
DIRECT_URL=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Necesaria para POST /api/auth/refresh (Grant refresh_token).
SUPABASE_ANON_KEY=

JWT_SECRET=change_me_min_32_characters_long_string
RESEND_API_KEY=
FRONTEND_URL=http://localhost:5173
INDEC_API_BASE_URL=https://apis.datos.gob.ar/series/api
BCRA_API_BASE_URL=https://api.bcra.gob.ar
