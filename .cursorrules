## 4. Database Schema (PostgreSQL via Supabase + Prisma)

### Tables

```
users
  id              UUID    PK  default uuid_generate_v4()
  email           String  unique
  name            String
  avatar_url      String?
  google_id       String? unique
  plan            Enum    PlanType  default FREE
  plan_expires_at DateTime?
  created_at      DateTime
  updated_at      DateTime  @updatedAt

locals
  id              UUID    PK
  user_id         UUID    FK → users
  name            String
  address         String?
  min_margin_pct  Decimal(5,2)  default 20.00
  currency        String        default 'ARS'
  is_active       Boolean       default true
  created_at      DateTime
  updated_at      DateTime  @updatedAt

categories
  id              UUID    PK
  local_id        UUID    FK → locals  onDelete: Cascade
  name            String
  color_hex       String? default '#16A34A'
  created_at      DateTime
  [unique: local_id + name]

products
  id              UUID    PK
  local_id        UUID    FK → locals      onDelete: Cascade
  category_id     UUID?   FK → categories  onDelete: SetNull
  name            String
  barcode         String?
  unit            String  default 'unidad'
  cost            Decimal(12,2)
  margin_pct      Decimal(5,2)
  sale_price      Decimal(12,2)   → calculated: cost * (1 + margin_pct/100)
  is_margin_alert Boolean         default false
  notes           String?
  is_active       Boolean         default true
  created_at      DateTime
  updated_at      DateTime  @updatedAt
  [unique: local_id + barcode where barcode IS NOT NULL]

price_history   (append-only, never modified)
  id              UUID    PK
  product_id      UUID    FK → products  onDelete: Cascade
  cost            Decimal(12,2)
  margin_pct      Decimal(5,2)
  sale_price      Decimal(12,2)
  change_reason   Enum    ChangeReason  (MANUAL | BULK_PCT | IPC_INDEC | BCRA_RATE | IMPORT)
  ipc_reference   Decimal(5,2)?
  note            String?
  recorded_at     DateTime  default now()

economic_indices
  id              UUID    PK
  type            Enum    IndexType  (IPC_INDEC | IPC_INDEC_ALIMENTOS | BCRA_USD_OFICIAL | BCRA_USD_MEP)
  period          DateTime   (first day of the month)
  value_pct       Decimal(6,3)
  source_url      String?
  fetched_at      DateTime   default now()
  [unique: type + period]

price_lists
  id              UUID    PK
  local_id        UUID    FK → locals  onDelete: Cascade
  format          Enum    ExportFormat  (PNG | PDF)
  file_url        String?   (Supabase Storage URL)
  shared_via      String?
  created_at      DateTime  default now()

notifications
  id              UUID    PK
  user_id         UUID    FK → users  onDelete: Cascade
  type            Enum    NotifType  (NEW_IPC | MARGIN_ALERT | PLAN_EXPIRING | PLAN_EXPIRED | WELCOME)
  title           String
  body            String
  is_read         Boolean  default false
  metadata        Json?
  created_at      DateTime  default now()

subscriptions
  id                  UUID    PK
  user_id             UUID    FK → users  onDelete: Cascade
  plan                Enum    PlanType
  status              Enum    SubStatus  (ACTIVE | CANCELLED | EXPIRED | PENDING)
  mp_subscription_id  String?
  amount_ars          Decimal(10,2)
  billing_cycle       String  default 'monthly'
  started_at          DateTime  default now()
  expires_at          DateTime?
  cancelled_at        DateTime?
  created_at          DateTime  default now()
```

### PostgreSQL triggers (run once in Supabase SQL editor)

```sql
-- 1. Auto-insert into price_history on cost or margin change
CREATE OR REPLACE FUNCTION record_price_change()
RETURNS TRIGGER AS $$
BEGIN
  IF (OLD.cost <> NEW.cost OR OLD.margin_pct <> NEW.margin_pct) THEN
    INSERT INTO price_history(product_id, cost, margin_pct, sale_price, change_reason)
    VALUES (NEW.id, NEW.cost, NEW.margin_pct, NEW.sale_price, 'MANUAL');
  END IF;
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_products_price_history
  AFTER UPDATE ON products
  FOR EACH ROW EXECUTE FUNCTION record_price_change();

-- 2. Auto-update updated_at
CREATE OR REPLACE FUNCTION set_updated_at()
RETURNS TRIGGER AS $$
BEGIN NEW.updated_at = NOW(); RETURN NEW; END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_users_updated_at   BEFORE UPDATE ON users    FOR EACH ROW EXECUTE FUNCTION set_updated_at();
CREATE TRIGGER trg_locals_updated_at  BEFORE UPDATE ON locals   FOR EACH ROW EXECUTE FUNCTION set_updated_at();
CREATE TRIGGER trg_products_updated_at BEFORE UPDATE ON products FOR EACH ROW EXECUTE FUNCTION set_updated_at();
```

